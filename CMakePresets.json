{
    "version": 7,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 27,
        "patch": 0
    },
    "include": [],
    "configurePresets": [
        {
            "name": "workflow-base",
            "hidden": true,
            "generator": "Ninja",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "toolset": {
                "value": "host=x64",
                "strategy": "external"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "RESPOND_BUILD_PIC": "ON",
                "RESPOND_BUILD_TESTS": "ON",
                "RESPOND_BUILD_BENCH": "OFF",
                "RESPOND_BUILD_WARNINGS": "ON",
                "RESPOND_CALCULATE_COVERAGE": "OFF",
                "RESPOND_BUILD_DOCS": "OFF",
                "RESPOND_INSTALL": "OFF",
                "RESPOND_SYSTEM_INCLUDES": "OFF",
                "RESPOND_NO_EXCEPTIONS": "OFF"
            }
        },
        {
            "name": "shared",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/shared",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "ON"
            }
        },
        {
            "name": "static",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/static",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "OFF"
            }
        },
        {
            "name": "test-debug",
            "displayName": "Debug Tests Configuration",
            "description": "Create a debuggable shared library for testing",
            "inherits": [
                "shared",
                "workflow-base"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "test-release",
            "displayName": "Release Tests Configuration",
            "description": "Create a release shared library for testing",
            "inherits": [
                "shared",
                "workflow-base"
            ]
        },
        {
            "name": "test-debug-static",
            "displayName": "Static Debug Tests Configuration",
            "description": "Create a debuggable static library for testing",
            "inherits": [
                "static",
                "workflow-base"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "test-release-static",
            "displayName": "Static Release Tests Configuration",
            "description": "Create a release static library for testing",
            "inherits": [
                "static",
                "workflow-base"
            ]
        },
        {
            "name": "coverage",
            "displayName": "Coverage Tests Configuration",
            "description": "Target a linux distro to create a debuggable shared library for testing with coverage",
            "inherits": [
                "shared",
                "workflow-base"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "RESPOND_CALCULATE_COVERAGE": "ON"
            }
        },
        {
            "name": "benchmark",
            "displayName": "Benchmark the Shared Library",
            "description": "Target a linux distro to build release benchmark artifacts",
            "inherits": [
                "workflow-base",
                "shared"
            ],
            "cacheVariables": {
                "RESPOND_BUILD_BENCH": "ON",
                "RESPOND_BUILD_TESTS": "OFF"
            }
        },
        {
            "name": "package-shared",
            "displayName": "Package the Shared Library",
            "description": "Build release package artifacts for the shared library.",
            "inherits": [
                "workflow-base",
                "shared"
            ],
            "cacheVariables": {
                "RESPOND_BUILD_TESTS": "OFF",
                "RESPOND_INSTALL": "ON"
            }
        },
        {
            "name": "package-static",
            "displayName": "Package the Static Library",
            "description": "Build release package artifacts for the static library",
            "inherits": [
                "workflow-base",
                "static"
            ],
            "cacheVariables": {
                "RESPOND_BUILD_TESTS": "OFF",
                "RESPOND_INSTALL": "ON"
            }
        },
        {
            "name": "docs",
            "displayName": "Build Documentation",
            "description": "Build the documentation for the shared library.",
            "inherits": [
                "workflow-base",
                "shared"
            ],
            "cacheVariables": {
                "RESPOND_BUILD_DOCS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default-build",
            "hidden": true,
            "jobs": 8
        },
        {
            "name": "test-debug",
            "displayName": "Test Debug Build",
            "description": "Test the debuggable build of the shared library.",
            "inherits": "default-build",
            "configurePreset": "test-debug"
        },
        {
            "name": "test-release",
            "displayName": "Test Release Build",
            "description": "Test the realease build of the shared library.",
            "inherits": "default-build",
            "configurePreset": "test-release"
        },
        {
            "name": "test-debug-static",
            "displayName": "Test Debug Static Build",
            "description": "Test the debuggable build of the static library.",
            "inherits": "default-build",
            "configurePreset": "test-debug-static"
        },
        {
            "name": "test-release-static",
            "displayName": "Test Release Static Build",
            "description": "Test the realease build of the static library.",
            "inherits": "default-build",
            "configurePreset": "test-release-static"
        },
        {
            "name": "coverage",
            "displayName": "Coverage Build",
            "description": "Build the debuggable build of the shared library with coverage.",
            "inherits": "default-build",
            "configurePreset": "coverage"
        },
        {
            "name": "benchmark",
            "displayName": "Benchmark Build",
            "description": "Build the release build of the shared library with benchmark.",
            "inherits": "default-build",
            "configurePreset": "benchmark"
        },
        {
            "name": "package-shared",
            "displayName": "Release Shared Package Build",
            "inherits": "default-build",
            "configurePreset": "package-shared"
        },
        {
            "name": "package-static",
            "displayName": "Release Static Package Build",
            "inherits": "default-build",
            "configurePreset": "package-static"
        }
    ],
    "testPresets": [
        {
            "name": "default-test",
            "description": "Settings for all tests",
            "hidden": true,
            "output": {
                "verbosity": "verbose",
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error",
                "stopOnFailure": true
            },
            "filter": {
                "include": {
                    "name": "respond_*"
                }
            }
        },
        {
            "name": "test-debug",
            "displayName": "Test Debuggable Build",
            "description": "Test the debuggable build of the shared library.",
            "inherits": "default-test",
            "configurePreset": "test-debug"
        },
        {
            "name": "test-release",
            "displayName": "Test Release Build",
            "description": "Test the release build of the shared library.",
            "inherits": "default-test",
            "configurePreset": "test-release"
        },
        {
            "name": "test-debug-static",
            "displayName": "Test Debuggable Static Build",
            "description": "Test the debuggable build of the static library.",
            "inherits": "default-test",
            "configurePreset": "test-debug-static"
        },
        {
            "name": "test-release-static",
            "displayName": "Test Release Static Build",
            "description": "Test the release build of the static library.",
            "inherits": "default-test",
            "configurePreset": "test-release-static"
        },
        {
            "name": "coverage",
            "displayName": "Coverage Build",
            "description": "Test the debuggable build of the shared library with coverage.",
            "inherits": "default-test",
            "configurePreset": "coverage"
        }
    ],
    "packagePresets": [
        {
            "name": "default-package",
            "hidden": true,
            "generators": [
                "TGZ"
            ]
        },
        {
            "name": "debian-package",
            "inherits": "default-package",
            "hidden": true,
            "generators": [
                "DEB"
            ]
        },
        {
            "name": "rpm-package",
            "inherits": "default-package",
            "hidden": true,
            "generators": [
                "RPM"
            ]
        },
        {
            "name": "nsis-package",
            "inherits": "default-package",
            "hidden": true,
            "generators": [
                "NSIS"
            ]
        },
        {
            "name": "debian-shared",
            "inherits": "debian-package",
            "configurePreset": "package-shared"
        },
        {
            "name": "debian-static",
            "inherits": "debian-package",
            "configurePreset": "package-static"
        },
        {
            "name": "rpm-shared",
            "inherits": "rpm-package",
            "configurePreset": "package-shared"
        },
        {
            "name": "rpm-static",
            "inherits": "rpm-package",
            "configurePreset": "package-static"
        },
        {
            "name": "nsis-shared",
            "inherits": "nsis-package",
            "configurePreset": "package-shared"
        },
        {
            "name": "nsis-static",
            "inherits": "nsis-package",
            "configurePreset": "package-static"
        }
    ],
    "workflowPresets": [
        {
            "name": "test-debug-shared",
            "displayName": "Debug Tests",
            "description": "Run tests in debugging mode for the shared library.",
            "steps": [
                {
                    "type": "configure",
                    "name": "test-debug"
                },
                {
                    "type": "build",
                    "name": "test-debug"
                },
                {
                    "type": "test",
                    "name": "test-debug"
                }
            ]
        },
        {
            "name": "test-release-shared",
            "displayName": "Release Tests",
            "description": "Run tests in release mode for the shared library.",
            "steps": [
                {
                    "type": "configure",
                    "name": "test-release"
                },
                {
                    "type": "build",
                    "name": "test-release"
                },
                {
                    "type": "test",
                    "name": "test-release"
                }
            ]
        },
        {
            "name": "test-debug-static",
            "displayName": "Debug Static Tests",
            "description": "Run tests in debugging mode for the static library.",
            "steps": [
                {
                    "type": "configure",
                    "name": "test-debug-static"
                },
                {
                    "type": "build",
                    "name": "test-debug-static"
                },
                {
                    "type": "test",
                    "name": "test-debug-static"
                }
            ]
        },
        {
            "name": "test-release-static",
            "displayName": "Release Static Tests",
            "description": "Run tests in release mode for the static library.",
            "steps": [
                {
                    "type": "configure",
                    "name": "test-release-static"
                },
                {
                    "type": "build",
                    "name": "test-release-static"
                },
                {
                    "type": "test",
                    "name": "test-release-static"
                }
            ]
        }
    ]
}
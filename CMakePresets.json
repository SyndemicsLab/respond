{
    "version": 7,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 27,
        "patch": 0
    },
    "include": [],
    "configurePresets": [
        {
            "name": "shared-config",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/shared",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "ON"
            }
        },
        {
            "name": "static-config",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/static",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "OFF"
            }
        },
        {
            "name": "debug-config",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "RESPOND_BUILD_TESTS": "ON",
                "RESPOND_INSTALL": "OFF",
                "RESPOND_CALCULATE_COVERAGE": "ON"
            }
        },
        {
            "name": "release-config",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "RESPOND_BUILD_TESTS": "OFF",
                "RESPOND_INSTALL": "ON",
                "RESPOND_BUILD_DOCS": "ON",
                "RESPOND_CALCULATE_COVERAGE": "OFF"
            }
        },
        {
            "name": "default-config",
            "hidden": true,
            "generator": "Ninja",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "toolset": {
                "value": "host=x64",
                "strategy": "external"
            },
            "cacheVariables": {
                "RESPOND_BUILD_PIC": "ON",
                "RESPOND_BUILD_BENCH": "OFF",
                "RESPOND_BUILD_WARNINGS": "ON",
                "RESPOND_SYSTEM_INCLUDES": "OFF",
                "RESPOND_NO_EXCEPTIONS": "OFF"
            }
        },
        {
            "name": "debug-shared-config",
            "displayName": "Debug, Shared",
            "description": "Target a linux distro to create a debuggable shared library",
            "inherits": [
                "debug-config",
                "shared-config",
                "default-config"
            ]
        },
        {
            "name": "debug-static-config",
            "displayName": "Debug, Static",
            "description": "Target a linux distro to create a debuggable static library",
            "inherits": [
                "debug-config",
                "static-config",
                "default-config"
            ]
        },
        {
            "name": "release-shared-config",
            "displayName": "Release, Shared",
            "description": "Target a linux distro to create a release shared library",
            "inherits": [
                "release-config",
                "shared-config",
                "default-config"
            ]
        },
        {
            "name": "release-static-config",
            "displayName": "Release, Static",
            "description": "Target a linux distro to create a release static library",
            "inherits": [
                "release-config",
                "static-config",
                "default-config"
            ]
        },
        {
            "name": "benchmark-static-config",
            "displayName": "Benchmark, Static",
            "description": "Target a linux distro to build release benchmark artifacts",
            "inherits": [
                "release-config",
                "static-config",
                "default-config"
            ],
            "cacheVariables": {
                "RESPOND_BUILD_BENCH": "ON",
                "RESPOND_BUILD_TESTS": "OFF",
                "RESPOND_BUILD_DOCS": "OFF",
                "RESPOND_INSTALL": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default-build",
            "hidden": true,
            "jobs": 8
        },
        {
            "name": "release-shared-build",
            "displayName": "Release Shared Build",
            "inherits": "default-build",
            "configurePreset": "release-shared-config"
        },
        {
            "name": "release-static-build",
            "displayName": "Release Static Build",
            "inherits": "default-build",
            "configurePreset": "release-static-config"
        },
        {
            "name": "debug-shared-build",
            "displayName": "Debug Shared Build",
            "inherits": "default-build",
            "configurePreset": "debug-shared-config"
        },
        {
            "name": "debug-static-build",
            "displayName": "Debug Static Build",
            "inherits": "default-build",
            "configurePreset": "debug-static-config"
        },
        {
            "name": "benchmark-static-build",
            "displayName": "Benchmark Static Build",
            "inherits": "default-build",
            "configurePreset": "benchmark-static-config"
        }
    ],
    "testPresets": [
        {
            "name": "default-test",
            "description": "Settings for all tests",
            "hidden": true,
            "output": {
                "verbosity": "verbose",
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error",
                "stopOnFailure": true
            },
            "filter": {
                "include": {
                    "name": "respond_*"
                }
            }
        },
        {
            "name": "debug-shared-test",
            "displayName": "Test, Debug, Shared",
            "description": "Enable output and stop on failure",
            "inherits": "default-test",
            "configurePreset": "debug-shared-config"
        },
        {
            "name": "debug-static-test",
            "displayName": "Test, Debug, Static",
            "description": "Enable output and stop on failure",
            "inherits": "default-test",
            "configurePreset": "debug-static-config"
        }
    ],
    "packagePresets": [
        {
            "name": "default-package",
            "hidden": true,
            "generators": [
                "TGZ"
            ]
        },
        {
            "name": "debian-package",
            "inherits": "default-package",
            "hidden": true,
            "generators": [
                "DEB"
            ]
        },
        {
            "name": "rpm-package",
            "inherits": "default-package",
            "hidden": true,
            "generators": [
                "RPM"
            ]
        },
        {
            "name": "nsis-package",
            "inherits": "default-package",
            "hidden": true,
            "generators": [
                "NSIS"
            ]
        },
        {
            "name": "release-debian-shared-package",
            "inherits": "debian-package",
            "configurePreset": "release-shared-config"
        },
        {
            "name": "release-debian-static-package",
            "inherits": "debian-package",
            "configurePreset": "release-static-config"
        },
        {
            "name": "release-rpm-shared-package",
            "inherits": "rpm-package",
            "configurePreset": "release-shared-config"
        },
        {
            "name": "release-rpm-static-package",
            "inherits": "rpm-package",
            "configurePreset": "release-static-config"
        },
        {
            "name": "release-nsis-shared-package",
            "inherits": "nsis-package",
            "configurePreset": "release-shared-config"
        },
        {
            "name": "release-nsis-static-package",
            "inherits": "nsis-package",
            "configurePreset": "release-static-config"
        }
    ],
    "workflowPresets": [
        {
            "name": "test-debug-shared-workflow",
            "displayName": "Test, Debug, Shared",
            "description": "Testing the debug shared library workflow.",
            "steps": [
                {
                    "type": "configure",
                    "name": "debug-shared-config"
                },
                {
                    "type": "build",
                    "name": "debug-shared-build"
                },
                {
                    "type": "test",
                    "name": "debug-shared-test"
                }
            ]
        },
        {
            "name": "test-debug-static-workflow",
            "displayName": "Test, Debug, Static",
            "description": "Testing the debug static library workflow.",
            "steps": [
                {
                    "type": "configure",
                    "name": "debug-static-config"
                },
                {
                    "type": "build",
                    "name": "debug-static-build"
                },
                {
                    "type": "test",
                    "name": "debug-static-test"
                }
            ]
        },
        {
            "name": "benchmark-static-workflow",
            "displayName": "Benchmark, Static",
            "description": "Build benchmark artifacts for performance testing.",
            "steps": [
                {
                    "type": "configure",
                    "name": "benchmark-static-config"
                },
                {
                    "type": "build",
                    "name": "benchmark-static-build"
                }
            ]
        },
        {
            "name": "package-release-debian-shared-workflow",
            "displayName": "Package, Release, Debian, Shared",
            "description": "Packaging the release shared library with debian",
            "steps": [
                {
                    "type": "configure",
                    "name": "release-shared-config"
                },
                {
                    "type": "build",
                    "name": "release-shared-build"
                },
                {
                    "type": "package",
                    "name": "release-debian-shared-package"
                }
            ]
        },
        {
            "name": "package-release-debian-static-workflow",
            "displayName": "Package, Release, Debian, Static",
            "description": "Packaging the release static library with debian",
            "steps": [
                {
                    "type": "configure",
                    "name": "release-static-config"
                },
                {
                    "type": "build",
                    "name": "release-static-build"
                },
                {
                    "type": "package",
                    "name": "release-debian-static-package"
                }
            ]
        },
        {
            "name": "package-release-rpm-shared-workflow",
            "displayName": "Package, Release, RPM, Shared",
            "description": "Packaging the release shared library with RPM",
            "steps": [
                {
                    "type": "configure",
                    "name": "release-shared-config"
                },
                {
                    "type": "build",
                    "name": "release-shared-build"
                },
                {
                    "type": "package",
                    "name": "release-rpm-shared-package"
                }
            ]
        },
        {
            "name": "package-release-rpm-static-workflow",
            "displayName": "Package, Release, RPM, Static",
            "description": "Packaging the release static library with RPM",
            "steps": [
                {
                    "type": "configure",
                    "name": "release-static-config"
                },
                {
                    "type": "build",
                    "name": "release-static-build"
                },
                {
                    "type": "package",
                    "name": "release-rpm-static-package"
                }
            ]
        },
        {
            "name": "package-release-nsis-shared-workflow",
            "displayName": "Package, Release, NSIS, Shared",
            "description": "Packaging the release shared library with NSIS",
            "steps": [
                {
                    "type": "configure",
                    "name": "release-shared-config"
                },
                {
                    "type": "build",
                    "name": "release-shared-build"
                },
                {
                    "type": "package",
                    "name": "release-nsis-shared-package"
                }
            ]
        },
        {
            "name": "package-release-nsis-static-workflow",
            "displayName": "Package, Release, NSIS, Static",
            "description": "Packaging the release static library with NSIS",
            "steps": [
                {
                    "type": "configure",
                    "name": "release-static-config"
                },
                {
                    "type": "build",
                    "name": "release-static-build"
                },
                {
                    "type": "package",
                    "name": "release-nsis-static-package"
                }
            ]
        }
    ]
}